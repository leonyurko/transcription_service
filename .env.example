# Copy to .env and adjust as needed.

# Model — options: tiny, base, small, medium, large-v2, large-v3, large-v3-turbo,
#         distil-large-v2, distil-large-v3
TRANSCRIBE_MODEL_SIZE=large-v3-turbo

# Device — auto | cpu | cuda
TRANSCRIBE_DEVICE=auto

# Compute precision — auto | int8 | int8_float16 | float16 | float32
TRANSCRIBE_COMPUTE_TYPE=auto

# Default language (leave empty for auto-detection)
# TRANSCRIBE_DEFAULT_LANGUAGE=en

# API key — leave empty to disable authentication
# TRANSCRIBE_API_KEY=your-secret-key

# Max upload size in MB
TRANSCRIBE_MAX_UPLOAD_MB=500

# Server
TRANSCRIBE_HOST=0.0.0.0
TRANSCRIBE_PORT=8000
